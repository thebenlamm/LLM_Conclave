# OpenAI API Key (for GPT models like gpt-4o, gpt-4-turbo, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for Claude models like claude-sonnet-4-5, etc.)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# xAI API Key (for Grok models)
XAI_API_KEY=your_xai_api_key_here

# Google API Key (preferred variable name for Gemini models)
GOOGLE_API_KEY=your_google_api_key_here

# Gemini alias also supported by the provider loader
# GEMINI_API_KEY=your_google_api_key_here

# Mistral AI API Key (for Mistral models like mistral-large-latest, codestral-latest, etc.)
MISTRAL_API_KEY=your_mistral_api_key_here

# ---------------------------------------------------------------------------
# Context path allowlist (advanced, optional)
#
# By default the MCP server only accepts `context` file paths that resolve
# inside its working directory. To reference specs in sibling repos from a
# local stdio MCP setup, list extra absolute roots here — colon-separated,
# PATH-style. This env var is HONORED ONLY under the stdio transport. On SSE
# / REST deployments it is silently ignored (fail-closed). NEVER set this on
# a network-exposed Conclave server.
#
# CONCLAVE_ALLOWED_CONTEXT_ROOTS=/Users/you/Workspace:/Users/you/.claude/plans
